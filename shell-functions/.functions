# FZF functions
  # fh - repeat history
  fh() {
    eval $( ([ -n "$ZSH_NAME" ] && fc -l 1 || history) | fzf +s --tac | sed -E 's/ *[0-9]*\*? *//' | sed -E 's/\\/\\\\/g')
  }

  fcd() {
    local dir
    dir=$(find ${1:-.} -path '*/\.*' -prune \
        -o -type d -print 2> /dev/null | fzf +m) &&
    cd "$dir"
  }

  # fkill - kill processes - list only the ones you can kill. Modified the earlier script.
  fkill() {
    local pid
    if [ "$UID" != "0" ]; then
      pid=$(ps -f -u $UID | sed 1d | fzf -m | awk '{print $2}')
    else
      pid=$(ps -ef | sed 1d | fzf -m | awk '{print $2}')
    fi

    if [ "x$pid" != "x" ]
    then
      echo $pid | xargs kill -${1:-9}
    fi
  }

  # fs [FUZZY PATTERN] - Select selected tmux session
  # #   - Bypass fuzzy finder if there's only one match (--select-1)
  # #   - Exit if there's no match (--exit-0)
  fs() {
    local session
    session=$(tmux list-sessions -F "#{session_name}" | \
      fzf --query="$1" --select-1 --exit-0) &&
      tmux switch-client -t "$session"
    }

  # ftpane - switch pane (@george-b)
  ftpane() {
    local panes current_window current_pane target target_window target_pane
    panes=$(tmux list-panes -s -F '#I:#P - #{pane_current_path} #{pane_current_command}')
    current_pane=$(tmux display-message -p '#I:#P')
    current_window=$(tmux display-message -p '#I')

    target=$(echo "$panes" | grep -v "$current_pane" | fzf +m --reverse) || return

    target_window=$(echo $target | awk 'BEGIN{FS=":|-"} {print$1}')
    target_pane=$(echo $target | awk 'BEGIN{FS=":|-"} {print$2}' | cut -c 1)

    if [[ $current_window -eq $target_window ]]; then
      tmux select-pane -t ${target_window}.${target_pane}
    else
      tmux select-pane -t ${target_window}.${target_pane} &&
        tmux select-window -t $target_window
    fi
  }

# Docker
  dpsf() {
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.State}}"
  }

# Claude Code: pin a stable session id on new interactive sessions so that
# tmux-resurrect relaunches the *exact* session after a restart -- even when
# several sessions share one directory. Pairs with the tmux option
# `@resurrect-processes '"~claude"'`, which restores the saved argv verbatim.
  claude() {
    emulate -L zsh
    local -a args; args=("$@")
    local i sid=""

    # Restore path: resurrect relaunches a saved pane as `claude --session-id X`.
    # Reusing --session-id errors ("already in use"), so if session X exists on
    # disk, rewrite the launch to `--resume X` to continue that conversation.
    for (( i = 1; i <= ${#args}; i++ )); do
      case "${args[i]}" in
        --session-id)   sid="${args[i+1]}"; break ;;
        --session-id=*) sid="${args[i]#--session-id=}"; break ;;
      esac
    done
    if [[ -n "$sid" ]]; then
      local -a found; found=( "$HOME"/.claude/projects/*/"$sid".jsonl(N) )
      if (( ${#found} )); then
        local -a out; local skip=0
        for (( i = 1; i <= ${#args}; i++ )); do
          if (( skip )); then skip=0; continue; fi
          case "${args[i]}" in
            --session-id)   out+=(--resume "$sid"); skip=1 ;;
            --session-id=*) out+=(--resume "$sid") ;;
            *)              out+=("${args[i]}") ;;
          esac
        done
        command claude "${out[@]}"; return
      fi
    fi

    # Don't pin for headless/session-selecting/help/version flags or subcommands.
    for (( i = 1; i <= ${#args}; i++ )); do
      case "${args[i]}" in
        -p|--print|-r|--resume|-c|--continue|--session-id|--session-id=*|--fork-session|--from-pr|-h|--help|-v|--version)
          command claude "${args[@]}"; return ;;
      esac
      if [[ "${args[i]}" != -* ]]; then
        case "${args[i]}" in
          agents|auth|auto-mode|config|doctor|install|mcp|plugin|plugins|project|setup-token|ultrareview|update|upgrade|migrate-installer)
            command claude "${args[@]}"; return ;;
        esac
        break
      fi
    done

    # Fresh interactive session: pin a new id so it can be resumed after a restart.
    command claude --session-id "$(< /proc/sys/kernel/random/uuid)" "${args[@]}"
  }
